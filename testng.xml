<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BeforeSuite">
	<groups>
		<run>
			<include name="smoke"></include>
			<exclude name="sanity"></exclude>
		</run>
	</groups>
	<test thread-count="5" name="Assertion and Annotation">
		<classes>
			<class name="testngTestcases.Assertions" />
			<class name="testngTestcases.TestNGAnnotations" />

		</classes>
	</test> <!-- BeforeTest -->

	<test thread-count="5" name="Priority and DependsOn">
		<classes>
			<class name="testngTestcases.Priority" />
			<class name="testngTestcases.DependsOn" />
		</classes>
	</test>
	
</suite>

